# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtualenv / uv
.venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Secrets — per-user, never committed
.env
.env.*
!.env.example

# dbfresh observation store (data, not config)
dbfresh.db
*.db-wal
*.db-shm

# Beads: commit the JSONL export, not the local DB (see .beads/.gitignore)
.beads/*.db
.beads/*.db-wal
.beads/*.db-shm

# Python version pin (local tooling)
.python-version

# Local tool state
.abacus/
.claude/

# Project-local scratch
tmp/

# Docs: generated reference pages and the built site are build artifacts
docs/reference/
site/

# Textual snapshot test failure report (regenerated per run, not a baseline)
snapshot_report.html
