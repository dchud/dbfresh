# Copy to .env next to your config (e.g. config.yaml), fill in real values,
# and never commit the real .env -- it's gitignored; only .env.example is
# tracked. See config.example.yaml for the sources that reference these.

# SQL Server connection URL: sqlserver://user:password@host:port/Database
MSSQL_URL=sqlserver://reader:StrongPassw0rd@sqlserver.internal:1433/WarehouseDB

# Databricks SQL warehouse: host, HTTP path, and a personal access token,
# all from the warehouse's Connection Details in the Databricks UI.
DATABRICKS_HOST=dbc-abc12345-6789.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/abcdef0123456789
DATABRICKS_TOKEN=dapi-your-personal-access-token
